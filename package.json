{
  "name": "prompt-area-docs",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev --turbopack",
    "prebuild": "pnpm registry:build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "registry:build": "shadcn build",
    "typecheck": "tsc --noEmit",
    "package:build": "pnpm --filter prompt-area build",
    "package:typecheck": "pnpm --filter prompt-area typecheck",
    "package:check": "pnpm --filter prompt-area lint:exports",
    "release": "node scripts/release.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "lefthook install",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@posthog/types": "^1.392.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.7.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "posthog-js": "^1.398.3",
    "prompt-area": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "pretty-quick": "^4.2.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.17",
      "undici": ">=7.28.0 <8",
      "flatted": ">=3.4.2",
      "hono": ">=4.12.15",
      "@hono/node-server": ">=1.19.14",
      "path-to-regexp": ">=8.4.2",
      "postcss": ">=8.5.10",
      "esbuild": "0.28.1",
      "brace-expansion@1": "^1.1.12",
      "brace-expansion@2": "^2.0.2",
      "brace-expansion@>=4": "^5.0.5",
      "picomatch@<3": "^2.3.2",
      "picomatch@>=4": "^4.0.4"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
